#!/usr/bin/env bash
set -euo pipefail

attention_dir="/tmp/claude-attention"

# Gather all claude panes
panes=$(tmux list-panes -a -F '#{pane_id}|#{session_name}|#{window_name}|#{pane_current_command}' \
    | grep '|claude$') || true

# Prune stale attention files
if [[ -d "$attention_dir" ]]; then
    live_set=$(printf '%s\n' "$panes" | cut -d'|' -f1)
    for f in "$attention_dir"/%*; do
        [[ -f "$f" ]] || continue
        [[ "$live_set" == *"$(basename "$f")"* ]] || rm -f "$f"
    done
fi

[[ -z "$panes" ]] && exit 0
[[ ! -d "$attention_dir" ]] && exit 0

# Find pane with oldest attention timestamp (longest waiting)
oldest_pane=""
oldest_ts=""

while IFS='|' read -r pane_id _session _window _cmd; do
    attention_file="${attention_dir}/${pane_id}"
    [[ -f "$attention_file" ]] || continue
    ts=$(< "$attention_file")
    if [[ -z "$oldest_ts" ]] || (( ts < oldest_ts )); then
        oldest_ts="$ts"
        oldest_pane="$pane_id"
    fi
done <<< "$panes"

[[ -z "$oldest_pane" ]] && exit 0

# Clear attention state
rm -f "${attention_dir}/${oldest_pane}"
tmux set-option -t "$oldest_pane" -p -u @claude_attention 2>/dev/null || true

tmux switch-client -t "$oldest_pane"
