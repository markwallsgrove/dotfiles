#!/usr/bin/env bash
set -euo pipefail
exec 2> /tmp/tmux-jira-start.log
trap 'echo "" > /dev/tty; echo "ERROR: Command failed (exit $?). See /tmp/tmux-jira-start.log" > /dev/tty; read -n1 < /dev/tty' ERR

log() { echo "[$(date '+%H:%M:%S')] $*" >&2; }

# Load secrets for non-interactive shell context (tmux popup)
# shellcheck source=/dev/null
[[ -f ~/.secrets ]] && source ~/.secrets

# ── Continue path: runs inside a tmux session pane ───────────────────────────
if [[ "${1:-}" == "--continue" ]]; then
    KEY="${2:?missing KEY}"
    worktree_dest="${3:?missing worktree_dest}"
    repo_dir="${4:?missing repo_dir}"
    key_lower="${KEY,,}"

    context_file="/tmp/jira-context-${KEY}.txt"
    outcome_file="/tmp/jira-outcome-${KEY}.yaml"
    rm -f "$outcome_file"

    # ── Phase 6: Claude discussion ───────────────────────────────────────
    log "Phase 6: Claude discussion (worktree: $worktree_dest)"
    builtin cd "$worktree_dest"
    mise trust --quiet 2>/dev/null || true
    claude "$(cat "${context_file}")

---

IMPORTANT RULES:
1. This is a DISCUSSION ONLY. Do NOT implement anything. Do NOT create or modify any files in the project.
2. Discuss the ticket with me: ask clarifying questions, suggest an approach, and refine the requirements.
3. Keep everything HIGH LEVEL and CONCEPTUAL. No code, no file paths, no function names, no implementation details. Think product/design level, not engineering level.
4. You SHOULD read and explore the codebase to understand what already exists. Do NOT ask the user about what exists — find out yourself. Use this understanding to inform the discussion, but keep your responses conceptual.
5. When I say we are done discussing, write ONLY the YAML outcome file below and nothing else. The output must also be high level and conceptual — no code references.

When discussion is complete, write a YAML file to ${outcome_file} with these fields:

proceed: true
refined_description: |
  full updated ticket description
acceptance_criteria: |
  acceptance criteria
implementation_notes: |
  implementation notes

Then tell me you are done and I should close this popup."
    log "Claude discussion finished"

    # ── Phase 7: Outcome check ───────────────────────────────────────────
    log "Phase 7: Outcome check"
    if [[ ! -f "$outcome_file" ]]; then
        log "No outcome file found at $outcome_file"
        echo "No outcome file found. Exiting."
        sleep 2
        exit 0
    fi

    log "Outcome file found: $(cat "$outcome_file")"
    proceed=$(yq eval '.proceed' "$outcome_file")
    log "Proceed: $proceed"
    if [[ "$proceed" != "true" ]]; then
        log "proceed=false, exiting"
        echo "Outcome: proceed=false. Exiting."
        sleep 2
        exit 0
    fi

    refined_description=$(yq eval '.refined_description' "$outcome_file")
    implementation_notes=$(yq eval '.implementation_notes' "$outcome_file")
    acceptance_criteria=$(yq eval '.acceptance_criteria' "$outcome_file")

    # ── Phase 8: Jira update ─────────────────────────────────────────────
    log "Phase 8: Jira update"
    if [[ -z "$refined_description" || "$refined_description" == "null" ]]; then
        log "Empty refined_description, skipping Jira update"
    else
        summary=$(jira issue view "$KEY" --plain --comments 0 2>/dev/null | head -1 | sed 's/^[[:space:]]*//')
        log "Summary: $summary"
        log "Updating Jira ticket description"
        echo "$refined_description" | jira issue edit "$KEY" --no-input 2>/dev/null || true
    fi

    # ── Phase 9: Bootstrap + exec claude ─────────────────────────────────
    log "Phase 9: Bootstrap + exec claude"
    summary="${summary:-$(jira issue view "$KEY" --plain --comments 0 2>/dev/null | head -1 | sed 's/^[[:space:]]*//')}"

    prompt="Jira issue ${KEY}: ${summary}

Implementation notes:
${implementation_notes}

Acceptance criteria:
${acceptance_criteria}

Instructions:
1. Review the codebase and the description above to understand the issue
2. Ask clarifying questions if anything is ambiguous
3. Write tests first, then implement the change
4. Run all checks (linting, formatting, type checking, and tests) and ensure they all pass
5. Create a PR, push the code, and open the PR in the browser"

    rm -f "$context_file" "$outcome_file"
    log "Cleaned up temp files, exec-ing claude"
    exec claude "$prompt"
fi

# ── Popup path: quick fzf selections ────────────────────────────────────────

# ── Phase 1: Issue picker ────────────────────────────────────────────────────

log "Phase 1: Issue picker"
assignee=$(jira me)
log "Assignee: $assignee"

selected_issue=$(jira issue list \
    --assignee "$assignee" \
    --status "~Done" \
    --status "~Won't Do" \
    --plain \
    --columns KEY,STATUS,SUMMARY \
    --no-headers \
    2>/dev/null \
    | fzf \
        --prompt="Select Jira issue: " \
        --preview 'jira issue view {1} --plain 2>/dev/null' \
        --preview-window=right:60% \
        --height=80% \
        --reverse) || true

if [[ -z "$selected_issue" ]]; then
    log "No issue selected, exiting"
    exit 0
fi

KEY=$(echo "$selected_issue" | awk '{print $1}')
key_lower="${KEY,,}"
log "Selected issue: $KEY"

# Write context file for Claude discussion
context_file="/tmp/jira-context-${KEY}.txt"
jira issue view "$KEY" --plain --comments 0 2>/dev/null > "$context_file"
log "Context file written: $context_file ($(wc -c < "$context_file") bytes)"

# ── Phase 2: Repo picker ─────────────────────────────────────────────────────

log "Phase 2: Repo picker"
repo_dir=$(find ~/projects -maxdepth 5 -name ".git" -type d \
    -not -path "*/node_modules/*" \
    -not -path "*/.worktrees/*" \
    -not -path "*/vendor/*" \
    2>/dev/null \
    | sed 's|/\.git$||' \
    | sort \
    | fzf --prompt="Select project: " --height=40% --reverse) || true

if [[ -z "$repo_dir" ]]; then
    log "No repo selected, exiting"
    exit 0
fi
log "Selected repo: $repo_dir"

# ── Phase 3: Fetch + base branch selection ────────────────────────────────────

log "Phase 3: Fetch + base branch"
git -C "$repo_dir" fetch --quiet 2>/dev/null || true

base_branch=$({
    git -C "$repo_dir" branch --format='%(refname:short)' 2>/dev/null
    git -C "$repo_dir" branch -r --format='%(refname:short)' 2>/dev/null \
        | grep -v '^[^/]*/HEAD$' \
        | grep -v '^[^/]*$' \
        | sed 's|^[^/]*/||'
} | sort -u | fzf --prompt="Select base branch: " --height=40% --reverse) || true

if [[ -z "$base_branch" ]]; then
    log "No base branch selected, exiting"
    exit 0
fi
log "Base branch: $base_branch"

# ── Phase 4: Branch name + worktree creation ─────────────────────────────────

log "Phase 4: Branch + worktree"
default_branch="feat/${key_lower}-"
log "Default branch name: $default_branch"

session_pattern="${key_lower//\//-}"
matching_sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null \
    | grep -iF "$session_pattern" || true)
log "Session pattern: $session_pattern matches: ${matching_sessions:-none}"

fzf_output=$(echo "$matching_sessions" | grep -v '^$' | fzf \
    --print-query \
    --prompt="Branch name or session: " \
    --query="${key_lower}-" \
    --header="Select session or type new branch" \
    --height=40% --reverse) || true

query=$(echo "$fzf_output" | sed -n '1p')
selection=$(echo "$fzf_output" | sed -n '2p')
log "Parsed query='$query' selection='$selection'"

if [[ -n "$selection" ]]; then
    target_session="$selection"
    branch="$query"
    if [[ -z "$branch" ]]; then
        branch="feat/${key_lower}-"
    fi
else
    target_session=""
    branch="$query"
    if [[ -n "$branch" && "$branch" != */* ]]; then
        branch="feat/$branch"
    fi
fi
log "Branch: $branch target_session: ${target_session:-none}"

if [[ -z "$branch" ]]; then
    log "No branch name entered, exiting"
    exit 0
fi

repo_name=$(basename "$repo_dir")

# Check if branch already has a worktree
worktree_path=$(git -C "$repo_dir" worktree list --porcelain \
    | awk -v branch="refs/heads/$branch" '
        /^worktree /{ wt = substr($0, 10) }
        /^branch /{ if (substr($0, 8) == branch) print wt }
    ')

if [[ -n "$worktree_path" && -d "$worktree_path" ]]; then
    worktree_dest="$worktree_path"
    log "Existing worktree found: $worktree_dest"
elif [[ -n "$worktree_path" && ! -d "$worktree_path" ]]; then
    log "Stale worktree entry found, pruning: $worktree_path"
    git -C "$repo_dir" worktree prune
    parent_dir=$(dirname "$repo_dir")
    branch_dir_name="${branch//\//-}"
    worktree_dest="$parent_dir/.worktrees/$repo_name/$branch_dir_name"
    log "Recreating worktree at: $worktree_dest"

    if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch"; then
        log "Branch exists locally, checking out"
        git -C "$repo_dir" worktree add "$worktree_dest" "$branch"
    elif git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        log "Branch exists on remote, tracking"
        git -C "$repo_dir" worktree add --track -b "$branch" "$worktree_dest" "origin/$branch"
    else
        log "Creating new branch from $base_branch"
        git -C "$repo_dir" worktree add -b "$branch" "$worktree_dest" "$base_branch"
    fi
else
    parent_dir=$(dirname "$repo_dir")
    branch_dir_name="${branch//\//-}"
    worktree_dest="$parent_dir/.worktrees/$repo_name/$branch_dir_name"
    log "Creating worktree at: $worktree_dest"

    if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch"; then
        log "Branch exists locally, checking out"
        git -C "$repo_dir" worktree add "$worktree_dest" "$branch"
    elif git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        log "Branch exists on remote, tracking"
        git -C "$repo_dir" worktree add --track -b "$branch" "$worktree_dest" "origin/$branch"
    else
        log "Creating new branch from $base_branch"
        git -C "$repo_dir" worktree add -b "$branch" "$worktree_dest" "$base_branch"
    fi
fi

log "Worktree dest: $worktree_dest"
zoxide add "$worktree_dest"

# ── Phase 5: Launch tmux session with --continue ─────────────────────────────

log "Phase 5: Launch tmux session"
if [[ -n "${target_session:-}" ]]; then
    existing_session="$target_session"
else
    existing_session=$(tmux list-sessions -F '#{session_name}' 2>/dev/null \
        | grep -F "$key_lower" | head -1) || true
fi
log "Existing session search for '$key_lower': ${existing_session:-none}"

if [[ -n "$existing_session" ]]; then
    log "Adding window to existing session: $existing_session"
    tmux new-window -t "$existing_session" -n "$repo_name" -c "$worktree_dest"
    tmux split-window -t "$existing_session:$repo_name" -h -p 50 -c "$worktree_dest" \
        "tmux-jira-start --continue ${KEY} ${worktree_dest} ${repo_dir}"
    tmux select-pane -t "$existing_session:$repo_name.0"
    tmux switch-client -t "$existing_session:$repo_name" 2>/dev/null || true
else
    log "Creating new session via tmux-sessionizer"
    cat > "$worktree_dest/.tmux-sessionizer" <<HYDRATE
tmux rename-window "${repo_name}"
tmux split-window -h -p 50 "tmux-jira-start --continue ${KEY} ${worktree_dest} ${repo_dir}"
HYDRATE
    log "Hydrate hook written"
    exec tmux-sessionizer "$worktree_dest"
fi
