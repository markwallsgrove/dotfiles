#!/usr/bin/env bash
set -euo pipefail
exec 2> /tmp/tmux-task-merge.log
trap 'echo "" > /dev/tty; echo "ERROR: Command failed (exit $?). See /tmp/tmux-task-merge.log" > /dev/tty; read -n1 < /dev/tty' ERR

log() { echo "[$(date '+%H:%M:%S')] $*" >&2; }

# ── Phase 1: Session picker ─────────────────────────────────────────────────

log "Phase 1: Session picker"
current_session=$(tmux display-message -p '#S')

selected=$(
    tmux list-sessions -F '#{session_name}' |
        grep -v "^${current_session}$" |
        fzf --prompt="Select session to merge & close: " \
            --height=80% --reverse) || true

if [[ -z "$selected" ]]; then
    log "No session selected, exiting"
    exit 0
fi

session_name="$selected"
log "Selected session: $session_name"

# ── Phase 2: Resolve worktree and branch ─────────────────────────────────────

log "Phase 2: Resolve context"
worktree_path=$(tmux list-panes -t "$session_name" -F '#{pane_current_path}' | head -1)
log "Worktree path: $worktree_path"

branch=$(git -C "$worktree_path" rev-parse --abbrev-ref HEAD)
log "Branch: $branch"

repo_root=$(git -C "$worktree_path" worktree list --porcelain \
    | awk '/^worktree /{ print substr($0, 10); exit }')
log "Repo root: $repo_root"

# ── Phase 3: Check PR and CI status ─────────────────────────────────────────

log "Phase 3: Check PR"
pr_json=$(gh pr view "$branch" --repo "$(git -C "$worktree_path" remote get-url origin)" --json number,title,url,statusCheckRollup,state 2>/dev/null || true)

if [[ -z "$pr_json" ]]; then
    echo "No PR found for branch '$branch'. Exiting." > /dev/tty
    sleep 2
    exit 0
fi

pr_state=$(echo "$pr_json" | jq -r '.state')
if [[ "$pr_state" == "MERGED" ]]; then
    echo "PR is already merged." > /dev/tty
    sleep 2
    exit 0
fi

pr_number=$(echo "$pr_json" | jq -r '.number')
pr_title=$(echo "$pr_json" | jq -r '.title')
pr_url=$(echo "$pr_json" | jq -r '.url')
log "PR #$pr_number: $pr_title ($pr_url)"

checks_failing=false
check_summary=$(echo "$pr_json" | jq -r '
  .statusCheckRollup // [] |
  map(select(.status != "COMPLETED" or .conclusion != "SUCCESS")) |
  length')

if [[ "$check_summary" -gt 0 ]]; then
    checks_failing=true
    echo "CI checks are failing or pending for PR #$pr_number" > /dev/tty
    echo "" > /dev/tty
    gh pr checks "$pr_number" --repo "$(git -C "$worktree_path" remote get-url origin)" > /dev/tty 2>/dev/null || true
    echo "" > /dev/tty

    override=$(echo -e "no\nyes" | fzf --prompt="Override and merge anyway? " --height=10% --reverse) || true
    if [[ "$override" != "yes" ]]; then
        log "User chose not to override, exiting"
        exit 0
    fi
    log "User chose to override failing checks"
fi

# ── Phase 4: Squash merge ───────────────────────────────────────────────────

log "Phase 4: Squash merge"

fzf_output=$(echo "" | fzf \
    --print-query \
    --prompt="Commit message: " \
    --query="$pr_title" \
    --height=10% --reverse 2>&1) || true

commit_msg=$(echo "$fzf_output" | head -1)

if [[ -z "$commit_msg" ]]; then
    log "No commit message entered, exiting"
    exit 0
fi
log "Commit message: $commit_msg"

remote_url=$(git -C "$worktree_path" remote get-url origin)
merge_args=(pr merge "$pr_number" --repo "$remote_url" --squash --subject "$commit_msg" --delete-branch)

if [[ "$checks_failing" == "true" ]]; then
    merge_args+=(--admin)
fi

echo "Merging PR #$pr_number..." > /dev/tty
gh "${merge_args[@]}"
log "PR merged"

# ── Phase 5: Cleanup worktree and session ────────────────────────────────────

log "Phase 5: Cleanup"

log "Removing worktree: $worktree_path"
git -C "$repo_root" worktree remove "$worktree_path" --force 2>/dev/null || true

log "Deleting local branch: $branch"
git -C "$repo_root" branch -D "$branch" 2>/dev/null || true

log "Killing session: $session_name"
tmux kill-session -t "$session_name" 2>/dev/null || true

echo "Done! PR #$pr_number merged, worktree removed, session closed." > /dev/tty
log "Complete"
sleep 2
