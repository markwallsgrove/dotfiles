#!/usr/bin/env bash
set -euo pipefail

# Select repository
repo_dir=$(find ~/projects -maxdepth 5 -name ".git" -type d \
    -not -path "*/node_modules/*" \
    -not -path "*/.worktrees/*" \
    -not -path "*/vendor/*" \
    2>/dev/null \
    | sed 's|/\.git$||' \
    | sort \
    | fzf --prompt="Select repository: " --height=40% --reverse) || true

if [[ -z "$repo_dir" ]]; then
    exit 0
fi

# Fetch latest refs
git -C "$repo_dir" fetch --quiet 2>/dev/null || true

# Select or create branch
fzf_output=$({
    git -C "$repo_dir" branch --format='%(refname:short)' 2>/dev/null
    git -C "$repo_dir" branch -r --format='%(refname:short)' 2>/dev/null \
        | grep -v '^[^/]*/HEAD$' \
        | grep -v '^[^/]*$' \
        | sed 's|^[^/]*/||'
} | sort -u | fzf --print-query --prompt="Select/create branch: " --height=40% --reverse 2>&1) || true

query=$(echo "$fzf_output" | sed -n '1p')
match=$(echo "$fzf_output" | sed -n '2p')

branch="${match:-$query}"

if [[ -z "$branch" ]]; then
    exit 0
fi

# Resolve existing worktree for this branch
worktree_path=$(git -C "$repo_dir" worktree list --porcelain \
    | awk -v branch="refs/heads/$branch" '
        /^worktree /{ wt = substr($0, 10) }
        /^branch /{ if (substr($0, 8) == branch) print wt }
    ')

if [[ -n "$worktree_path" ]]; then
    zoxide add "$worktree_path"
    exec tmux-sessionizer "$worktree_path"
fi

# Create new worktree
repo_name=$(basename "$repo_dir")
parent_dir=$(dirname "$repo_dir")
branch_dir_name="${branch//\//-}"
worktree_dest="$parent_dir/.worktrees/$repo_name/$branch_dir_name"

if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$repo_dir" worktree add "$worktree_dest" "$branch"
elif git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
    git -C "$repo_dir" worktree add --track -b "$branch" "$worktree_dest" "origin/$branch"
else
    git -C "$repo_dir" worktree add -b "$branch" "$worktree_dest" main
fi

zoxide add "$worktree_dest"
exec tmux-sessionizer "$worktree_dest"
