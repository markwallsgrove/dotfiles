#!/usr/bin/env bash
set -euo pipefail

attention_dir="/tmp/claude-attention"

# Single tmux call — gather all claude panes
panes=$(tmux list-panes -a -F '#{pane_id}|#{session_name}|#{window_name}|#{pane_current_command}' \
    | grep '|claude$') || true

# Prune stale attention files using live pane set
if [[ -d "$attention_dir" ]]; then
    live_set=$(printf '%s\n' "$panes" | cut -d'|' -f1)
    for f in "$attention_dir"/%*; do
        [[ -f "$f" ]] || continue
        [[ "$live_set" == *"$(basename "$f")"* ]] || rm -f "$f"
    done
fi

if [[ -z "$panes" ]]; then
    echo "No Claude instances found."
    read -r -n 1
    exit 0
fi

now=$(date +%s)
fzf_input=""

while IFS='|' read -r pane_id session window _cmd; do
    attention_file="${attention_dir}/${pane_id}"
    if [[ -f "$attention_file" ]]; then
        age=$(( (now - $(< "$attention_file")) / 60 ))
        fzf_input+="! ${session} > ${window}  (${age}m ago)"$'\t'"${pane_id}"$'\n'
    else
        fzf_input+="  ${session} > ${window}"$'\t'"${pane_id}"$'\n'
    fi
done <<< "$panes"

# Sort: attention (!) first
fzf_input=$(printf '%s' "$fzf_input" | sort -r)

selected=$(printf '%s' "$fzf_input" \
    | fzf --with-nth=1 --delimiter=$'\t' \
        --prompt="Claude instances> " \
        --header="! = needs attention | Enter = switch" \
        --preview='tmux capture-pane -t {2} -p -S -100' \
        --preview-window=right:50%:follow) || true

[[ -z "$selected" ]] && exit 0

target=$(printf '%s' "$selected" | awk -F$'\t' '{print $2}' | tr -d ' ')

# Clear attention state
rm -f "${attention_dir}/${target}"
tmux set-option -t "$target" -p -u @claude_attention 2>/dev/null || true

tmux switch-client -t "$target"
