#!/usr/bin/env bash
set -euo pipefail
exec 2> /tmp/tmux-task-start.log
trap 'echo "" > /dev/tty; echo "ERROR: Command failed (exit $?). See /tmp/tmux-task-start.log" > /dev/tty; read -n1 < /dev/tty' ERR

log() { echo "[$(date '+%H:%M:%S')] $*" >&2; }

outcome_file="/tmp/task-outcome-$$.yaml"
rm -f "$outcome_file"

# ── Phase 1: Repo picker ─────────────────────────────────────────────────────

log "Phase 1: Repo picker"
repo_dir=$(find ~/projects -maxdepth 5 -name ".git" -type d \
    -not -path "*/node_modules/*" \
    -not -path "*/.worktrees/*" \
    -not -path "*/vendor/*" \
    2>/dev/null \
    | sed 's|/\.git$||' \
    | sort \
    | fzf --prompt="Select project: " --height=40% --reverse) || true

if [[ -z "$repo_dir" ]]; then
    log "No repo selected, exiting"
    exit 0
fi
log "Selected repo: $repo_dir"

# ── Phase 2: Fetch + base branch selection ────────────────────────────────────

log "Phase 2: Fetch + base branch"
git -C "$repo_dir" fetch --quiet 2>/dev/null || true

base_branch=$({
    git -C "$repo_dir" branch --format='%(refname:short)' 2>/dev/null
    git -C "$repo_dir" branch -r --format='%(refname:short)' 2>/dev/null \
        | grep -v '^[^/]*/HEAD$' \
        | grep -v '^[^/]*$' \
        | sed 's|^[^/]*/||'
} | sort -u | fzf --prompt="Select base branch: " --height=40% --reverse) || true

if [[ -z "$base_branch" ]]; then
    log "No base branch selected, exiting"
    exit 0
fi
log "Base branch: $base_branch"

# ── Phase 3: Claude discussion ───────────────────────────────────────────────

log "Phase 3: Claude discussion (repo: $repo_dir)"
builtin cd "$repo_dir"
mise trust --quiet 2>/dev/null || true

claude "IMPORTANT RULES:
1. This is a DISCUSSION ONLY. Do NOT implement anything. Do NOT create or modify any files.
2. Start by asking what the user is working on. Ask clarifying questions, suggest an approach, refine the requirements.
3. Keep everything HIGH LEVEL and CONCEPTUAL. No code, no file paths, no function names, no implementation details.
4. You SHOULD read and explore the codebase to understand what already exists. Use this to inform the discussion.
5. When the user says we are done discussing, write ONLY the YAML outcome file and nothing else.

When discussion is complete, write a YAML file to ${outcome_file}:

proceed: true
slug: short-kebab-case-identifier
title: Human readable task title
refined_description: |
  full updated task description
acceptance_criteria: |
  acceptance criteria
implementation_notes: |
  implementation notes

Then tell the user you are done and they should close this popup."

log "Claude discussion finished"

# ── Phase 4: Outcome check ───────────────────────────────────────────────────

log "Phase 4: Outcome check"
if [[ ! -f "$outcome_file" ]]; then
    log "No outcome file found at $outcome_file"
    echo "No outcome file found. Exiting."
    sleep 2
    exit 0
fi

proceed=$(yq eval '.proceed' "$outcome_file")
if [[ "$proceed" != "true" ]]; then
    log "proceed=false, exiting"
    echo "Outcome: proceed=false. Exiting."
    sleep 2
    exit 0
fi

task_slug=$(yq eval '.slug' "$outcome_file")
task_title=$(yq eval '.title' "$outcome_file")
refined_description=$(yq eval '.refined_description' "$outcome_file")
implementation_notes=$(yq eval '.implementation_notes' "$outcome_file")
acceptance_criteria=$(yq eval '.acceptance_criteria' "$outcome_file")
log "Slug: $task_slug title: $task_title"

# ── Phase 5: Branch name + worktree creation ─────────────────────────────────

log "Phase 5: Branch + worktree"
repo_name=$(basename "$repo_dir")

session_pattern="${task_slug//\//-}"
matching_sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null \
    | grep -iF "$session_pattern" || true)
log "Session pattern: $session_pattern matches: ${matching_sessions:-none}"

fzf_output=$(echo "$matching_sessions" | grep -v '^$' | fzf \
    --print-query \
    --prompt="Branch name or session: " \
    --query="${task_slug}-" \
    --header="Select session or type new branch" \
    --height=40% --reverse) || true

query=$(echo "$fzf_output" | sed -n '1p')
selection=$(echo "$fzf_output" | sed -n '2p')
log "Parsed query='$query' selection='$selection'"

if [[ -n "$selection" ]]; then
    target_session="$selection"
    branch="$query"
    if [[ -z "$branch" ]]; then
        branch="feat/${task_slug}-"
    fi
else
    target_session=""
    branch="$query"
    if [[ -n "$branch" && "$branch" != */* ]]; then
        branch="feat/$branch"
    fi
fi
log "Branch: $branch target_session: ${target_session:-none}"

if [[ -z "$branch" ]]; then
    log "No branch name entered, exiting"
    exit 0
fi

worktree_path=$(git -C "$repo_dir" worktree list --porcelain \
    | awk -v branch="refs/heads/$branch" '
        /^worktree /{ wt = substr($0, 10) }
        /^branch /{ if (substr($0, 8) == branch) print wt }
    ')

if [[ -n "$worktree_path" && -d "$worktree_path" ]]; then
    worktree_dest="$worktree_path"
    log "Existing worktree found: $worktree_dest"
elif [[ -n "$worktree_path" && ! -d "$worktree_path" ]]; then
    log "Stale worktree entry found, pruning: $worktree_path"
    git -C "$repo_dir" worktree prune
    parent_dir=$(dirname "$repo_dir")
    branch_dir_name="${branch//\//-}"
    worktree_dest="$parent_dir/.worktrees/$repo_name/$branch_dir_name"
    log "Recreating worktree at: $worktree_dest"

    if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch"; then
        git -C "$repo_dir" worktree add "$worktree_dest" "$branch"
    elif git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        git -C "$repo_dir" worktree add --track -b "$branch" "$worktree_dest" "origin/$branch"
    else
        git -C "$repo_dir" worktree add -b "$branch" "$worktree_dest" "$base_branch"
    fi
else
    parent_dir=$(dirname "$repo_dir")
    branch_dir_name="${branch//\//-}"
    worktree_dest="$parent_dir/.worktrees/$repo_name/$branch_dir_name"
    log "Creating worktree at: $worktree_dest"

    if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch"; then
        git -C "$repo_dir" worktree add "$worktree_dest" "$branch"
    elif git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        git -C "$repo_dir" worktree add --track -b "$branch" "$worktree_dest" "origin/$branch"
    else
        git -C "$repo_dir" worktree add -b "$branch" "$worktree_dest" "$base_branch"
    fi
fi

log "Worktree dest: $worktree_dest"
zoxide add "$worktree_dest"
rm -f "$outcome_file"

# ── Phase 6: Launch tmux session ─────────────────────────────────────────────

log "Phase 6: Launch tmux session"
if [[ -n "${target_session:-}" ]]; then
    existing_session="$target_session"
else
    existing_session=$(tmux list-sessions -F '#{session_name}' 2>/dev/null \
        | grep -F "$task_slug" | head -1) || true
fi
log "Existing session search for '$task_slug': ${existing_session:-none}"

prompt_file="/tmp/task-prompt-${task_slug}.txt"
cat > "$prompt_file" <<PROMPT
Task: ${task_title}

Description:
${refined_description}

Implementation notes:
${implementation_notes}

Acceptance criteria:
${acceptance_criteria}

Instructions:
1. Review the codebase and the description above to understand the task
2. Ask clarifying questions if anything is ambiguous
3. Write tests first, then implement the change
4. Run all checks (linting, formatting, type checking, and tests) and ensure they all pass
5. Create a PR, push the code, and open the PR in the browser
PROMPT

if [[ -n "$existing_session" ]]; then
    log "Adding window to existing session: $existing_session"
    tmux new-window -t "$existing_session" -n "$repo_name" -c "$worktree_dest"
    tmux split-window -t "$existing_session:$repo_name" -h -p 50 -c "$worktree_dest" \
        "claude \"\$(cat ${prompt_file})\"; rm -f ${prompt_file}"
    tmux select-pane -t "$existing_session:$repo_name.0"
    tmux switch-client -t "$existing_session:$repo_name" 2>/dev/null || true
else
    log "Creating new session via tmux-sessionizer"
    # shellcheck disable=SC2016
    printf 'tmux rename-window "%s"\nclaude "$(cat %s)"\nrm -f %s\n' \
        "$repo_name" "$prompt_file" "$prompt_file" \
        > "$worktree_dest/.tmux-sessionizer"
    log "Hydrate hook written"
    exec tmux-sessionizer "$worktree_dest"
fi
